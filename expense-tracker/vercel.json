{
    "version": 2,
    "functions": {
        "api/expense.js": {
            "runtime": "nodejs18.x"
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/expense.js"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}